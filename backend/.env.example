MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/learnmate
JWT_SECRET=change-this-to-a-long-random-secret
PORT=5000

# Required for forgot-password OTP emails
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=LearnMate <your-email@gmail.com>

# Optional values used by npm run seed:lookup when no admin exists
SEED_ADMIN_USERNAME=admin@
SEED_ADMIN_EMAIL=admin@learnmate.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_NAME=System Administrator
